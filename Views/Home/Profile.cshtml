@model List<Bookly.Models.PublicacionesCompletas>
@using Bookly.Helpers
@using Bookly.Models

@{
    ViewData["Title"] = "Perfil";
}

<section class="profileInfo primerElemento">
    <img src="~/img/default.webp" alt="pfp">
    <div class="profileId">
        <h1 class="nombreCompleto">@HtmlHelpers.ToUpperPrimeraLetra(ViewBag.usuario.nombreComp)</h1>
        <div class="profileStats">
            <div class="pieceOfInfo">
                <span>@HtmlHelpers.PasarAñoATexto(ViewBag.usuario.ano)</span>
                <span>@($"{ViewBag.usuario.especialidad} {ViewBag.usuario.curso}")</span>
            </div>
            <div class="pieceOfInfo">
                <span>0</span>
                <span>ventas cerradas</span>
            </div>
            <div class="pieceOfInfo">
                <span>@Model.Count</span>
                <span>publicaciones</span>
            </div>
        </div>
        <form id="aboutMeContainer" method="post" action="@Url.Action("UpdateAboutMe", "Usuarios")" class="aboutMeContainer">
            @Html.AntiForgeryToken()
            <p class="aboutMe" id="aboutMe">@ViewBag.usuario.aboutMe</p>
            <button id="btnEditAboutMe" style="display:flex; align-items:center; gap:4px; padding:0;" type="button">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" /><path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z" /><path d="M16 5l3 3" /></svg>
                @(ViewBag.usuario.aboutMe == null || ViewBag.usuario.aboutMe == "" ? "Agregar descripción" : "Editar descripción")
            </button>
        </form>
    </div>
    <button class="logoutBtn" onclick="window.location.href='@Url.Action("Logout", "Usuarios")'">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 8v-2a2 2 0 0 1 2 -2h7a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-7a2 2 0 0 1 -2 -2v-2" /><path d="M15 12h-12l3 -3" /><path d="M6 15l-3 -3" /></svg>
        Cerrar sesión
    </button>
</section>

<section class="publicaciones">
    <div class="publicacionesEnProfileTitulo">
        <h1>Publicaciones</h1>
        @if (Model != null && Model.Count > 5)
        {
            <div style="display:flex; gap:10px; align-items:center;">
                <button class="secondaryBtn" onclick="window.location.href='@Url.Action("MisPublicaciones", "Home")'">
                    Ver todo (+@(Model.Count - 5))
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
                </button>
            </div>
        }
    </div>
    <section class="cardsPublicadas">
        @{
            // Card de publicar siempre primero
        }
        <div class="libro publicarCard" onclick="window.location.href='@Url.Action("Publicar", "Book")'">
            <div class="publicarCardInner">
                <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 5l0 14" /><path d="M5 12l14 0" /></svg>
                <span>Publicar libro</span>
            </div>
        </div>
        @if (Model != null && Model.Count > 0)
        {
            var preview = Model.Take(5).ToList();
            foreach (PublicacionesCompletas libro in preview)
            {
                <div class="libro inProfile">
                    <div class="libroImgContainer">
                        @if (libro.imagen != null)
                        {
                            <img src="data:image/webp;base64,@Convert.ToBase64String(libro.imagen)" alt="imagen del libro" />
                        }
                        else
                        {
                            <img src="~/img/book-placeholder.webp" alt="imagen del libro" />
                        }
                        <section class="libroActionsContainer">
                            <form class="desearBtnForm editar" action="@Url.Action("Editar", "Book")" method="get" style="display:inline;">
                                <input type="hidden" name="id" value="@libro.id" />
                                <button type="submit" title="Editar" onclick="event.stopPropagation();">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1" /><path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z" /><path d="M16 5l3 3" /></svg>
                                </button>
                            </form>
                            <form class="desearBtnForm" action="@Url.Action("Eliminar", "Book")" method="post" onsubmit="return confirm('¿Seguro que querés eliminar esta publicación?');" style="display:inline;">
                                <input type="hidden" name="id" value="@libro.id" />
                                <button type="submit" title="Eliminar" onclick="event.stopPropagation();">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 7l16 0" /><path d="M10 11l0 6" /><path d="M14 11l0 6" /><path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" /><path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" /></svg>
                                </button>
                            </form>
                        </section>
                    </div>
                    <div class="nombreYMateriaContainer">
                        <h1>@HtmlHelpers.ToUpperPrimeraLetra(libro.nombre)</h1>
                        <h2>@HtmlHelpers.ToUpperPrimeraLetra(libro.materia)</h2>
                    </div>
                    <h3>$@libro.precio</h3>
                    <div class="pillContainer">
                        <span class="pill" style="background-color:@HtmlHelpers.GetColor(libro.estadoLibro);">@libro.estadoLibro</span>
                        <span class="pill">@HtmlHelpers.PasarAñoATexto(libro.ano)</span>
                    </div>
                </div>
            }
            @if (Model.Count > 5)
            {
                // el contador ya está en el botón "Ver todo" del header
            }
        }
    </section>
</section>

@{
    var favoritos = ViewBag.favoritos as List<PublicacionesCompletas> ?? new List<PublicacionesCompletas>();
}

<section class="publicaciones">
    <div class="publicacionesEnProfileTitulo">
        <h1>Favoritos</h1>
        @if (favoritos.Count > 6)
        {
            <button class="secondaryBtn" onclick="window.location.href='@Url.Action("MisFavoritos", "Home")'">
                Ver todo (+@(favoritos.Count - 6))
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" /></svg>
            </button>
        }
    </div>
    <section class="cardsPublicadas">
        @if (favoritos.Count == 0)
        {
            <div class="no-result">
                <p>Todavía no agregaste libros a favoritos.</p>
            </div>
        }
        else
        {
            var favoritosPreview = favoritos.Take(6).ToList();
            foreach (PublicacionesCompletas libro in favoritosPreview)
            {
                <div class="libro" onclick="window.location.href='@Url.Action("Detalle", "Book", new { id = libro.id, idVendedor = libro.idVendedor })'">
                    <div class="libroImgContainer">
                        @if (libro.imagen != null)
                        {
                            <img src="data:image/webp;base64,@Convert.ToBase64String(libro.imagen)" alt="imagen del libro" />
                        }
                        else
                        {
                            <img src="~/img/book-placeholder.webp" alt="imagen del libro" />
                        }
                    </div>
                    <div class="nombreYMateriaContainer">
                        <h1>@HtmlHelpers.ToUpperPrimeraLetra(libro.nombre)</h1>
                        <h2>@HtmlHelpers.ToUpperPrimeraLetra(libro.materia)</h2>
                    </div>
                    <h3>$@libro.precio</h3>
                    <div class="pillContainer">
                        <span class="pill" style="background-color:@HtmlHelpers.GetColor(libro.estadoLibro);">@libro.estadoLibro</span>
                        <span class="pill">@HtmlHelpers.PasarAñoATexto(libro.ano)</span>
                    </div>
                </div>
            }
        }
    </section>
</section>
