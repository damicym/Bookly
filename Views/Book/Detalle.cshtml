@model Bookly.Models.PublicacionesCompletas
@using Bookly.Helpers

@{
    ViewData["Title"] = "Ver libro";
    var publicaciones = (List<PublicacionesCompletas>)ViewBag.Publicaciones;
    var vendedor = (Usuarios)ViewBag.Vendedor;
    var usuarioActual = (Usuarios)ViewBag.usuario;
    var max = publicaciones.Count < 4 ? publicaciones.Count : 4;
}

<div class="detalle-wrapper primerElemento">

    @* Columna izquierda: imagen *@
    <div class="detalle-col-imagen">
        <div class="detalle-imagen-box">
            @if (Model.imagen != null)
            {
                <img src="data:image/webp;base64,@Convert.ToBase64String(Model.imagen)" alt="imagen del libro" />
            }
            else
            {
                <img src="~/img/book-placeholder.webp" alt="imagen del libro" />
            }

            @* Botón favorito sobre la imagen, igual que en las cards *@
            <div class="libroActionsContainer">
                <form class="desearBtnForm hoverVerde" action="@Url.Action("Desear", "Book")" method="post" onsubmit="return desearLibro(event, this);">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.id" />
                    <input type="hidden" name="esDeseado" value="@Model.esDeseado" />
                    <button class="@(Model.esDeseado ? "deseado" : "")" type="submit" title="@(Model.esDeseado ? "Quitar de favoritos" : "Agregar a favoritos")">
                        @if (Model.esDeseado)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M6.979 3.074a6 6 0 0 1 4.988 1.425l.037 .033l.034 -.03a6 6 0 0 1 4.733 -1.44l.246 .036a6 6 0 0 1 3.364 10.008l-.18 .185l-.048 .041l-7.45 7.379a1 1 0 0 1 -1.313 .082l-.094 -.082l-7.493 -7.422a6 6 0 0 1 3.176 -10.215z"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M19.5 12.572l-7.5 7.428l-7.5 -7.428a5 5 0 1 1 7.5 -6.566a5 5 0 1 1 7.5 6.572"/></svg>
                        }
                    </button>
                </form>
            </div>

            @if (Model.esMasBarato)
            {
                <span class="tag-masbarato">
                    <svg class="tag-rayo" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M13 2L4.5 13.5H11L10 22L19.5 10.5H13L13 2Z"/></svg>
                    Mejor precio
                </span>
            }
        </div>
    </div>

    @* Columna central: datos *@
    <div class="detalle-col-datos">
        <div class="detalle-meta">
            <span class="detalle-pill" style="background-color:@HtmlHelpers.GetColor(Model.estadoLibro)">@HtmlHelpers.GetEstadoLabel(Model.estadoLibro)</span>
            <span class="detalle-pill">@HtmlHelpers.PasarAñoATexto(Model.ano)</span>
        </div>

        <h1 class="detalle-titulo">@Model.nombre</h1>
        <p class="detalle-materia">@Model.materia</p>
        <div class="detalle-precio">$@Model.precio</div>

        <div class="detalle-info-grid">
            <div class="detalle-info-item">
                <span class="detalle-info-label">Editorial</span>
                <span class="detalle-info-valor">@(string.IsNullOrWhiteSpace(Model.editorial) ? "—" : Model.editorial)</span>
            </div>
            <div class="detalle-info-item">
                <span class="detalle-info-label">Año de uso</span>
                <span class="detalle-info-valor">@HtmlHelpers.PasarAñoATexto(Model.ano)</span>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.descripcion))
        {
            <div class="detalle-descripcion">
                <p class="detalle-info-label">Descripción</p>
                <p>@Model.descripcion</p>
            </div>
        }

        <div class="detalle-acciones-row">
            <button class="mainBtn detalle-comprar-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 9h8" /><path d="M8 13h6" /><path d="M18 4a3 3 0 0 1 3 3v8a3 3 0 0 1 -3 3h-5l-5 3v-3h-2a3 3 0 0 1 -3 -3v-8a3 3 0 0 1 3 -3h12z" /></svg>
                Contactar vendedor
            </button>
        </div>
    </div>

    @* Columna derecha: vendedor *@
    <div class="detalle-col-vendedor">
        <div class="detalle-vendedor-card">
            <img src="~/img/default.webp" alt="foto de perfil" class="detalle-vendedor-img" />
            <p class="detalle-vendedor-nombre">@vendedor.nombreComp</p>
            <p class="detalle-vendedor-info">@($"{HtmlHelpers.PasarAñoATextoCompleto(vendedor.ano)} {vendedor.especialidad} {vendedor.curso}")</p>

            @if (max > 0)
            {
                <div class="detalle-vendedor-publics">
                    <span class="detalle-info-label">Otras publicaciones</span>
                    <div class="detalle-vendedor-grid">
                        @for (int i = 0; i < max; i++)
                        {
                            <a class="detalle-vendedor-thumb" href="@Url.Action("Detalle", "Book", new { id = publicaciones[i].id, idVendedor = publicaciones[i].idVendedor })">
                                @if (publicaciones[i].imagen != null)
                                {
                                    <img src="data:image/webp;base64,@Convert.ToBase64String(publicaciones[i].imagen)" alt="@publicaciones[i].nombre" />
                                }
                                else
                                {
                                    <img src="~/img/book-placeholder.webp" alt="@publicaciones[i].nombre" />
                                }
                                <span>@publicaciones[i].nombre</span>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

</div>
