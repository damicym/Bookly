@model Bookly.Models.PublicacionesCompletas
@using Bookly.Helpers

@{
    ViewData["Title"] = "Ver libro";
    var publicaciones = (List<PublicacionesCompletas>)ViewBag.Publicaciones;
    var vendedor = (Usuarios)ViewBag.Vendedor;
    var usuarioActual = (Usuarios)ViewBag.usuario;
    var max = publicaciones.Count < 4 ? publicaciones.Count : 4;
}

<section class="detalles primerElemento" style="padding-top: 40px; padding-bottom: 40px;">
    <div class="detallesFoto">
        <div class="detalleImgWrapper">
            <div class="detalleImgInner">
                @if (Model.imagen != null)
                {
                    <img src="data:image/webp;base64,@Convert.ToBase64String(Model.imagen)" alt="imagen del libro" />
                }
                else
                {
                    <img src="~/img/book-placeholder.webp" alt="imagen del libro" />
                }
            </div>

            @if (Model.esMasBarato)
            {
                <span class="tag-masbarato tag-masbarato-detalle">
                    <svg class="tag-rayo" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M13 2L4.5 13.5H11L10 22L19.5 10.5H13L13 2Z"/></svg>
                    Más barato
                </span>
            }

            <div class="detalleAcciones">
                <form class="desearBtnForm desearBtnFormDetalle hoverVerde" action="@Url.Action("Desear", "Book")" method="post" onsubmit="return desearLibro(event, this);">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.id" />
                    <input type="hidden" name="esDeseado" value="@Model.esDeseado" />
                    <button class="@(Model.esDeseado ? "deseado" : "")" type="submit">
                        @if (Model.esDeseado)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="currentColor"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M6.979 3.074a6 6 0 0 1 4.988 1.425l.037 .033l.034 -.03a6 6 0 0 1 4.733 -1.44l.246 .036a6 6 0 0 1 3.364 10.008l-.18 .185l-.048 .041l-7.45 7.379a1 1 0 0 1 -1.313 .082l-.094 -.082l-7.493 -7.422a6 6 0 0 1 3.176 -10.215z"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M19.5 12.572l-7.5 7.428l-7.5 -7.428a5 5 0 1 1 7.5 -6.566a5 5 0 1 1 7.5 6.572"/></svg>
                        }
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="detallesDatos">
        <div class="detalle-meta">
            <span class="detalle-pill" style="background-color:@HtmlHelpers.GetColor(Model.estadoLibro)">@Model.estadoLibro</span>
            <span class="detalle-pill">@HtmlHelpers.PasarAñoATexto(Model.ano)</span>
        </div>

        <h1 class="detalle-titulo">@Model.nombre</h1>
        <p class="detalle-materia">@Model.materia</p>
        <div class="detalle-precio">$@Model.precio</div>

        <div class="detalle-info-grid">
            <div class="detalle-info-item">
                <span class="detalle-info-label">Editorial</span>
                <span class="detalle-info-valor">@(string.IsNullOrWhiteSpace(Model.editorial) ? "—" : Model.editorial)</span>
            </div>
            <div class="detalle-info-item">
                <span class="detalle-info-label">Año de uso</span>
                <span class="detalle-info-valor">@HtmlHelpers.PasarAñoATexto(Model.ano)</span>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.descripcion))
        {
            <div class="detalle-descripcion">
                <p class="detalle-info-label">Descripción</p>
                <p>@Model.descripcion</p>
            </div>
        }

        <button class="mainBtn detalle-comprar-btn" style="white-space: nowrap; width: fit-content;">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 9h8" /><path d="M8 13h6" /><path d="M18 4a3 3 0 0 1 3 3v8a3 3 0 0 1 -3 3h-5l-5 3v-3h-2a3 3 0 0 1 -3 -3v-8a3 3 0 0 1 3 -3h12z" /></svg>
            Contactar vendedor
        </button>
    </div>
</section>

<section class="panel-wrapper open">
    <button id="toggleBtn" class="panel-btn">
        <svg id="toggleIcon" xmlns="http://www.w3.org/2000/svg" width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="#EFF2F1" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-layout-sidebar-left-collapse"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z" /><path d="M9 4v16" /><path d="M15 10l-2 2l2 2" /></svg>
    </button>

    <div id="sidePanel" class="side-panel">
        <img src="~/img/default.webp" alt="pfp" class="imgVenDetalle">
        <h3>@vendedor.nombreComp</h3>
        <div class="detallesVenInfo">
            <h4>@($"{HtmlHelpers.PasarAñoATexto(vendedor.ano)} {vendedor.especialidad} {vendedor.curso}")</h4>
        </div>
        <div class="detallesVenPublics">
            <h3>Publicaciones</h3>
            @for (int i = 0; i < max; i++)
            {
                if (publicaciones[i].imagen != null)
                {
                    <img src="data:image/webp;base64,@(Convert.ToBase64String(publicaciones[i].imagen))" />
                }
                else
                {
                    <img src="~/img/book-placeholder.webp" alt="imagen del libro" />
                }
            }
        </div>
    </div>
</section>

<script>
const wrapper = document.querySelector(".panel-wrapper");
const btn = document.getElementById("toggleBtn");
const icon = document.getElementById("toggleIcon");

const svgOpen = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#EFF2F1" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z" /><path d="M9 4v16" /><path d="M14 10l2 2l-2 2" /></svg>`;
const svgClosed = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#EFF2F1" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z" /><path d="M9 4v16" /><path d="M15 10l-2 2l2 2" /></svg>`;

icon.innerHTML = svgOpen;

btn.addEventListener("click", () => {
    wrapper.classList.toggle("open");
    icon.innerHTML = wrapper.classList.contains("open") ? svgOpen : svgClosed;
});
</script>
