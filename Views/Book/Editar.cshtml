@model Bookly.Models.PublicacionesCompletas

@{
    ViewData["Title"] = "Editar publicación";
}

@* La view de Editar no renderiza contenido propio.
   El modal vive en _Layout y se abre automáticamente con los datos del modelo. *@

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', async function() {
        if (typeof abrirEditarModal === 'function') {
            await abrirEditarModal(@Model.id);
        }

        // Al cerrar el modal, volver al perfil en lugar de quedarse en /Book/Editar
        var modal = document.getElementById('editarModal');
        if (modal) {
            var originalCerrar = window.cerrarEditarModal;
            window.cerrarEditarModal = function(e) {
                if (e && e.target !== modal) return;
                modal.classList.remove('login-modal-overlay--visible');
                document.body.style.overflow = '';
                window.location.href = '@Url.Action("Profile", "Home")';
            };
            var closeBtn = modal.querySelector('.login-modal-close');
            if (closeBtn) {
                closeBtn.onclick = function() {
                    modal.classList.remove('login-modal-overlay--visible');
                    document.body.style.overflow = '';
                    window.location.href = '@Url.Action("Profile", "Home")';
                };
            }
        }
    });
</script>
}
