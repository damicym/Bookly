@model Bookly.Models.Usuarios

@{
    ViewBag.Title = "Registrarse";
}

@* La view de Register no renderiza contenido propio.
   El modal vive en _Layout y se abre automáticamente. *@

@if (ViewBag.Error != null)
{
    <div style="display:none" id="registerServerError">@ViewBag.Error</div>
}

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var errEl = document.getElementById('registerServerError');
        if (errEl) {
            var modalErr = document.getElementById('registerModalError');
            if (modalErr) {
                modalErr.textContent = errEl.textContent;
                modalErr.style.display = 'block';
            }
        }
        if (typeof abrirRegisterModal === 'function') abrirRegisterModal();
    });
</script>
}
