@model Bookly.Models.Usuarios

@{
    ViewBag.Title = "Registrarse";
}

<div class="register-wrapper primerElemento">

    <div class="publicar-header">
        <h1>Creá tu cuenta</h1>
        <p>Completá tus datos y empezá a comprar y vender libros con otros estudiantes.</p>
    </div>

    @if (ViewBag.Error != null)
    {
        <p class="auth-error" style="max-width: 700px;">@ViewBag.Error</p>
    }

    <form asp-action="Register" method="post" autocomplete="off" class="register-form-new">

        <div class="publicar-seccion">
            <h3 class="publicar-seccion-titulo">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0" /><path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2" /></svg>
                Datos personales
            </h3>
            <div class="publicar-grid-2">
                <div class="campo">
                    <label for="DNI">DNI</label>
                    <input asp-for="DNI" id="DNI" placeholder="Ej.: 44123456" required autocomplete="off" pattern="\d+" autofocus title="Solo números" inputmode="numeric" />
                </div>
                <div class="campo">
                    <label for="nombreComp">Nombre y apellido</label>
                    <input asp-for="nombreComp" id="nombreComp" placeholder="Ej.: Juan Pérez" required autocomplete="off" pattern="^[A-Za-zÁÉÍÓÚáéíóúÑñ ]+$" title="Solo letras" />
                </div>
                <div class="campo">
                    <label for="password">Contraseña</label>
                    <div class="campo-password">
                        <input asp-for="password" type="password" id="password" placeholder="Creá una contraseña" required autocomplete="off" />
                        <button type="button" class="ojo-btn" onclick="togglePassword('password', this)">
                            <svg class="ojo-off" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" /><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6" /></svg>
                            <svg class="ojo-on" style="display:none" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 3l18 18" /><path d="M10.584 10.587a2 2 0 0 0 2.828 2.83" /><path d="M9.363 5.365a9 9 0 0 1 2.637 -.365c3.6 0 6.6 2 9 6c-.822 1.37 -1.722 2.519 -2.7 3.448m-2.168 1.816a9 9 0 0 1 -4.132 .736c-3.6 0 -6.6 -2 -9 -6c1.168 -1.948 2.494 -3.42 3.978 -4.418" /></svg>
                        </button>
                    </div>
                </div>
                <div class="campo">
                    <label for="confirmarPassword">Confirmar contraseña</label>
                    <div class="campo-password">
                        <input type="password" id="confirmarPassword" placeholder="Repetí tu contraseña" required autocomplete="off" />
                        <button type="button" class="ojo-btn" onclick="togglePassword('confirmarPassword', this)">
                            <svg class="ojo-off" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" /><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6" /></svg>
                            <svg class="ojo-on" style="display:none" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 3l18 18" /><path d="M10.584 10.587a2 2 0 0 0 2.828 2.83" /><path d="M9.363 5.365a9 9 0 0 1 2.637 -.365c3.6 0 6.6 2 9 6c-.822 1.37 -1.722 2.519 -2.7 3.448m-2.168 1.816a9 9 0 0 1 -4.132 .736c-3.6 0 -6.6 -2 -9 -6c1.168 -1.948 2.494 -3.42 3.978 -4.418" /></svg>
                        </button>
                    </div>
                    <small id="passwordError" class="register-password-error" style="display:none;">Las contraseñas no coinciden</small>
                </div>
            </div>
            <div class="campo publicar-desc-campo">
                <label for="aboutMe">Sobre mí <span class="campo-opcional">(opcional)</span></label>
                <textarea asp-for="aboutMe" id="aboutMe" name="aboutMe" placeholder="Contá algo sobre vos, tu año, tus materias..." class="publicar-desc-textarea"></textarea>
            </div>
        </div>

        <div class="publicar-seccion">
            <h3 class="publicar-seccion-titulo">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 19a9 9 0 0 1 9 0a9 9 0 0 1 9 0" /><path d="M3 6a9 9 0 0 1 9 0a9 9 0 0 1 9 0" /><path d="M3 6l0 13" /><path d="M12 6l0 13" /><path d="M21 6l0 13" /></svg>
                Datos escolares
            </h3>
            <div class="publicar-grid-2">
                <div class="campo">
                    <label for="ano">Año de ciclo</label>
                    <select id="ano" name="ano" required>
                        <option value="0">Seleccioná un año</option>
                        <option value="1">7mo grado</option>
                        <option value="2">1er año</option>
                        <option value="3">2do año</option>
                        <option value="4">3er año</option>
                        <option value="5">4to año</option>
                        <option value="6">5to año</option>
                    </select>
                </div>
                <div class="campo">
                    <label for="especialidad">Especialidad</label>
                    <select id="especialidad" name="especialidad">
                        <option value="">Seleccioná una especialidad</option>
                        <option value="Informatica">Informática</option>
                        <option value="Gestión">Gestión</option>
                        <option value="Producción Artística">Producción Artística</option>
                        <option value="Química">Química</option>
                        <option value="Mecatrónica">Mecatrónica</option>
                        <option value="Construcciones">Construcciones</option>
                    </select>
                </div>
                <div class="campo">
                    <label for="curso">División</label>
                    <input asp-for="curso" id="curso" placeholder="Ej.: A" maxlength="1" pattern="[A-Za-z]" title="Una letra (A-Z)" required autocomplete="off" />
                </div>
                <div class="campo">
                    <label for="organizacion">Organización</label>
                    <select id="organizacion" name="organizacion" disabled class="organizacion-disabled">
                        <option value="ORT">ORT</option>
                    </select>
                    <small class="org-info">Próximamente más organizaciones</small>
                </div>
            </div>
        </div>

        <div class="register-form-footer">
            <button type="submit" class="mainBtn publicar-submit">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l5 5l10 -10" /></svg>
                Crear cuenta
            </button>
            <p class="auth-footer">
                ¿Ya tenés cuenta? <a href="@Url.Action("Login", "Usuarios")">Iniciá sesión</a>
            </p>
        </div>

    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    // Especialidad habilitada solo desde 3er año
    const anoSelect = document.getElementById('ano');
    const especialidadSelect = document.getElementById('especialidad');

    function updateEspecialidadState() {
        const anoValue = parseInt(anoSelect.value, 10);
        if (anoValue >= 4) {
            especialidadSelect.disabled = false;
            especialidadSelect.classList.remove('organizacion-disabled');
        } else {
            especialidadSelect.disabled = true;
            especialidadSelect.classList.add('organizacion-disabled');
            especialidadSelect.value = "";
        }
    }

    anoSelect.addEventListener('change', updateEspecialidadState);
    updateEspecialidadState();

    // Validación confirmar contraseña
    const password = document.getElementById('password');
    const confirmar = document.getElementById('confirmarPassword');
    const errorMsg = document.getElementById('passwordError');
    const form = confirmar.closest('form');

    function validarPasswords() {
        if (confirmar.value && password.value !== confirmar.value) {
            errorMsg.style.display = 'block';
            confirmar.style.borderColor = 'rgba(215, 38, 61, 0.6)';
        } else {
            errorMsg.style.display = 'none';
            confirmar.style.borderColor = '';
        }
    }

    password.addEventListener('input', validarPasswords);
    confirmar.addEventListener('input', validarPasswords);

    form.addEventListener('submit', function (e) {
        if (password.value !== confirmar.value) {
            e.preventDefault();
            errorMsg.style.display = 'block';
            confirmar.focus();
        }
    });
});
</script>
