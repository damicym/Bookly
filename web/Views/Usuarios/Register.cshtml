@model Bookly.Models.Usuarios

@{
    ViewBag.Title = "Registrarse";
}

@* La view de Register no renderiza contenido propio.
   El modal vive en _Layout y se abre automáticamente. *@

@if (ViewBag.Error != null)
{
    <div style="display:none" id="registerServerError">@ViewBag.Error</div>
}

@section Scripts {
    <script src="~/js/register-page.js" asp-append-version="true"></script>
}
