@{
    ViewData["Title"] = "Login";
}

@* La view de Login no renderiza contenido propio.
   El modal vive en _Layout y se abre automáticamente. *@

@if (ViewBag.Error != null)
{
    <div style="display:none" id="loginServerError">@ViewBag.Error</div>
}

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Mostrar error del servidor si lo hay
        var errEl = document.getElementById('loginServerError');
        if (errEl) {
            var modalErr = document.getElementById('loginModalError');
            if (modalErr) {
                modalErr.textContent = errEl.textContent;
                modalErr.style.display = 'block';
            }
        }
        // Abrir el modal
        if (typeof abrirLoginModal === 'function') abrirLoginModal();
    });
</script>
}
