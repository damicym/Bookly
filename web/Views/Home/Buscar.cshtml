@using Bookly.Helpers
@using System.Collections.Generic
@using System.Linq
@{
    ViewData["Title"] = "Resultados de búsqueda";
    var materias = ViewBag.materias as IEnumerable<string> ?? Enumerable.Empty<string>();
    var anos = ViewBag.anos as IEnumerable<int> ?? Enumerable.Empty<int>();
    var editoriales = ViewBag.editoriales as IEnumerable<string> ?? Enumerable.Empty<string>();
}

<form style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div class="catalogo-layout">
    @* filtros sidebar *@
    <aside class="filtros-sidebar">
        <div class="filtros-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M4 4h16v2.172a2 2 0 0 1 -.586 1.414l-4.414 4.414v7l-6 2v-8.5l-4.48 -4.928a2 2 0 0 1 -.52 -1.345v-2.227z" /></svg>
            <span>Filtros</span>
            <button class="filtros-limpiar" id="btnLimpiarFiltros" type="button">Limpiar</button>
            <button class="filtros-toggle" id="btnToggleFiltros" type="button" aria-label="Colapsar filtros" aria-expanded="true">
                <svg class="filtros-toggle-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6l6 6"/></svg>
            </button>
        </div>

        <div class="filtros-scroll">

        @* Materia *@
        <div class="filtro-grupo">
            <button class="filtro-grupo-titulo" type="button" aria-expanded="true" data-target="listaMateria">
                <span>Materia</span>
                <svg class="filtro-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6l6 -6"/></svg>
            </button>
            <div class="filtro-lista" id="listaMateria">
                <label class="filtro-opcion">
                    <input type="radio" name="filtroMateria" value="" checked /> Todas las materias
                </label>
                @foreach (var materia in materias)
                {
                    <label class="filtro-opcion">
                        <input type="radio" name="filtroMateria" value="@materia" /> @materia
                    </label>
                }
            </div>
        </div>

        @* Año *@
        <div class="filtro-grupo">
            <button class="filtro-grupo-titulo" type="button" aria-expanded="true" data-target="listaAno">
                <span>Año</span>
                <svg class="filtro-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6l6 -6"/></svg>
            </button>
            <div class="filtro-lista" id="listaAno">
                <label class="filtro-opcion">
                    <input type="radio" name="filtroAno" value="" checked /> Todos los años
                </label>
                @foreach (var ano in anos)
                {
                    <label class="filtro-opcion">
                        <input type="radio" name="filtroAno" value="@ano" /> @HtmlHelpers.PasarAñoATexto(ano)
                    </label>
                }
            </div>
        </div>

        @* Estado *@
        <div class="filtro-grupo">
            <button class="filtro-grupo-titulo" type="button" aria-expanded="true" data-target="listaEstado">
                <span>Estado</span>
                <svg class="filtro-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6l6 -6"/></svg>
            </button>
            <div class="filtro-lista" id="listaEstado">
                <label class="filtro-opcion">
                    <input type="radio" name="filtroEstado" value="" checked /> Todos
                </label>
                <label class="filtro-opcion">
                    <input type="radio" name="filtroEstado" value="a" /> Como nuevo
                </label>
                <label class="filtro-opcion">
                    <input type="radio" name="filtroEstado" value="b" /> Pocas anotaciones
                </label>
                <label class="filtro-opcion">
                    <input type="radio" name="filtroEstado" value="d" /> Muy anotado
                </label>
            </div>
        </div>

        @* Editorial *@
        <div class="filtro-grupo">
            <button class="filtro-grupo-titulo" type="button" aria-expanded="true" data-target="listaEditorial">
                <span>Editorial</span>
                <svg class="filtro-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6l6 -6"/></svg>
            </button>
            <div class="filtro-lista" id="listaEditorial">
                <label class="filtro-opcion">
                    <input type="radio" name="filtroEditoriales" value="" checked /> Todas
                </label>
                @foreach (var editorial in editoriales)
                {
                    <label class="filtro-opcion">
                        <input type="radio" name="filtroEditoriales" value="@editorial" /> @editorial
                    </label>
                }
            </div>
        </div>

        @* Precio *@
        <div class="filtro-grupo">
            <button class="filtro-grupo-titulo" type="button" aria-expanded="true" data-target="listaPrecio">
                <span>Precio</span>
                <svg class="filtro-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6l6 -6"/></svg>
            </button>
            <div class="filtro-lista" id="listaPrecio">
                <div class="filtro-precio-row">
                    <div class="filtro-precio-input-wrap">
                        <span class="filtro-precio-signo">$</span>
                        <input type="text" id="filtroPrecioMin" placeholder="Mínimo" inputmode="numeric" autocomplete="off" />
                    </div>
                    <span class="filtro-precio-sep">—</span>
                    <div class="filtro-precio-input-wrap">
                        <span class="filtro-precio-signo">$</span>
                        <input type="text" id="filtroPrecioMax" placeholder="Máximo" inputmode="numeric" autocomplete="off" />
                    </div>
                </div>
            </div>
        </div>@* fin filtro-grupo precio *@

        </div>@* fin filtros-scroll *@

    </aside>

    @* ===== RESULTADOS ===== *@
    <div class="catalogo-resultados">
        <div class="catalogo-resultados-header">
            <div class="catalogo-titulo-row">
                <h2 class="busqueda-titulo">Catálogo</h2>
                <div class="orden-dropdowns">
                    <!-- Hidden selects para compatibilidad con buscar.js -->
                    <select id="selectOrdenEstado" style="display:none">
                        <option value="">Estado</option>
                        <option value="asc">Mejor estado</option>
                        <option value="desc">Peor estado</option>
                    </select>
                    <select id="selectOrdenPrecio" style="display:none">
                        <option value="">Precio</option>
                        <option value="asc">Menor precio</option>
                        <option value="desc">Mayor precio</option>
                    </select>

                    <div class="orden-dropdown-wrap">
                        <span class="orden-label">Ordenar por</span>
                        <div class="orden-custom-dropdown" data-select="selectOrdenEstado">
                            <button type="button" class="orden-custom-btn" aria-haspopup="listbox" aria-expanded="false">
                                <span class="orden-custom-text">Estado</span>
                                <svg class="orden-custom-chevron" xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6l6 -6"/></svg>
                            </button>
                            <ul class="orden-custom-list" role="listbox">
                                <li class="orden-custom-option" data-value="" role="option">Estado</li>
                                <li class="orden-custom-option" data-value="asc" role="option">Mejor estado</li>
                                <li class="orden-custom-option" data-value="desc" role="option">Peor estado</li>
                            </ul>
                        </div>
                    </div>

                    <div class="orden-dropdown-wrap">
                        <span class="orden-label">Ordenar por</span>
                        <div class="orden-custom-dropdown" data-select="selectOrdenPrecio">
                            <button type="button" class="orden-custom-btn" aria-haspopup="listbox" aria-expanded="false">
                                <span class="orden-custom-text">Precio</span>
                                <svg class="orden-custom-chevron" xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6l6 -6"/></svg>
                            </button>
                            <ul class="orden-custom-list" role="listbox">
                                <li class="orden-custom-option" data-value="" role="option">Precio</li>
                                <li class="orden-custom-option" data-value="asc" role="option">Menor precio</li>
                                <li class="orden-custom-option" data-value="desc" role="option">Mayor precio</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <div class="filtros-activos-chips" id="filtrosActivosChips"></div>
        </div>
        <section class="publicaciones">
            <section class="cardsPublicadas" id="resultados"></section>
        </section>
    </div>

</div>
