@{
    ViewData["Title"] = "Publicar";
}

<div class="publicar-wrapper primerElemento">
    <div class="publicar-header">
        <a href="javascript:history.back()" class="publicar-back-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6l6 6"/></svg>
            Volver
        </a>
        <h1>Nueva publicación</h1>
        <p>Completá los datos de tu libro para que otros estudiantes puedan encontrarlo.</p>
    </div>

    <form action="@Url.Action("Publicar", "Book")" method="post" enctype="multipart/form-data" class="publicar-form">

        <!-- Columna izquierda: imagen -->
        <div class="publicar-col publicar-col-imagen">
            <div class="publicar-imagen-preview" id="imagenPreviewContainer">
                <img id="imagenPreview" src="/img/book-placeholder.webp" alt="Preview del libro" />
                <label for="fileInput" class="edit-img-overlay">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M15 8h.01" /><path d="M3 6a3 3 0 0 1 3 -3h12a3 3 0 0 1 3 3v12a3 3 0 0 1 -3 3h-12a3 3 0 0 1 -3 -3v-12z" /><path d="M3 16l5 -5c.928 -.893 2.072 -.893 3 0l5 5" /><path d="M14 14l1 -1c.928 -.893 2.072 -.893 3 0l3 3" /></svg>
                    <span>Subir imagen</span>
                </label>
                <input name="imagen" accept="image/*" type="file" id="fileInput" style="display:none">
            </div>
            <p class="publicar-imagen-hint" id="fileName">Ningún archivo seleccionado</p>
        </div>

        <!-- Columna derecha: campos -->
        <div class="publicar-col publicar-col-campos">

            <div class="publicar-seccion">
                <h3 class="publicar-seccion-titulo">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 19a9 9 0 0 1 9 0a9 9 0 0 1 9 0" /><path d="M3 6a9 9 0 0 1 9 0a9 9 0 0 1 9 0" /><path d="M3 6l0 13" /><path d="M12 6l0 13" /><path d="M21 6l0 13" /></svg>
                    Información del libro
                    <small id="libroIndicator" class="libroExistenteIndicator"></small>
                </h3>
                <div class="publicar-grid-2">
                    <div class="campo">
                        <label for="nombre">Nombre</label>
                        <input type="text" id="nombre" name="libro.nombre" placeholder="Ej.: Toldot Israel" required autofocus autocomplete="off"/>
                        <input type="hidden" id="libroId" name="libro.id" value="" />
                    </div>
                    <div class="campo">
                        <label for="materia">Materia</label>
                        <input type="text" id="materia" name="libro.materia" placeholder="Ej.: Historia Judía" required />
                    </div>
                    <div class="campo">
                        <label for="ano">Nivel escolar</label>
                        <select id="ano" name="libro.ano" required>
                            <option value="0">Seleccioná un año</option>
                            <option value="1">7mo grado</option>
                            <option value="2">1er año</option>
                            <option value="3">2do año</option>
                            <option value="4">3er año</option>
                            <option value="5">4to año</option>
                            <option value="6">5to año</option>
                        </select>
                    </div>
                    <div class="campo">
                        <label for="editorial">Editorial</label>
                        <input type="text" id="editorial" name="libro.editorial" placeholder="Ej.: Editorial ORT" />
                    </div>
                </div>
            </div>

            <div class="publicar-seccion">
                <h3 class="publicar-seccion-titulo">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 7m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" /><path d="M3 11l9 -9l9 9l-9 9z" /></svg>
                    Detalles de la venta
                </h3>
                <div class="publicar-grid-2">
                    <div class="campo">
                        <label for="estadoLibro">Estado del libro</label>
                        <select id="estadoLibro" name="estadoLibro" required>
                            <option value="">Seleccioná un estado</option>
                            <option value="Como nuevo">Como nuevo</option>
                            <option value="Pocas anotaciones">Pocas anotaciones</option>
                            <option value="Muy anotado">Muy anotado</option>
                        </select>
                    </div>
                    <div class="campo">
                        <label for="precio">Precio ($)</label>
                        <input type="number" id="precio" name="precio" placeholder="0.00" step="0.01" min="0.01" required />
                    </div>
                </div>
                <div class="campo publicar-desc-campo">
                    <label for="descripcion">Descripción <span class="campo-opcional">(opcional)</span></label>
                    <textarea id="descripcion" name="descripcion" placeholder="Contá el estado del libro, si tiene subrayados, si le faltan páginas..." class="publicar-desc-textarea"></textarea>
                </div>
            </div>

            <button type="submit" id="publicarSubmitBtn" class="mainBtn publicar-submit">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l5 5l10 -10" /></svg>
                Publicar libro
            </button>
        </div>

    </form>
</div>

<script src="/js/site.js"></script>
<script>
(function() {
    var form = document.querySelector('.publicar-form');
    if (!form) return;
    form.addEventListener('submit', function() {
        var btn = document.getElementById('publicarSubmitBtn');
        if (typeof setButtonLoading === 'function') setButtonLoading(btn, true);
    });
})();
</script>
