@model Bookly.Models.PublicacionesCompletas

@{
    ViewData["Title"] = "Editar publicación";
}

@* La view de Editar no renderiza contenido propio.
   El modal vive en _Layout y se abre automáticamente con los datos del modelo. *@

<div id="editarPageConfig" hidden
     data-publicacion-id="@Model.id"
     data-profile-url="@Url.Action("Profile", "Home")"></div>

@section Scripts {
    <script src="~/js/editar.js" asp-append-version="true"></script>
}
